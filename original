"""
Energy landscape construction and analysis
"""
import numpy as np
from typing import Dict, List, Tuple
from scipy.spatial.distance import pdist, squareform
from sklearn.neighbors import NearestNeighbors
from sklearn.gaussian_process import GaussianProcessRegressor
from sklearn.gaussian_process.kernels import RBF, ConstantKernel
import matplotlib.pyplot as plt
import seaborn as sns

class LandscapeConstructor:
    """
    Construct and analyze energy landscapes using quasi-potential theory
    """
    
    def __init__(self):
        self.gp_model = None
        self.attractors = None
        self.barriers = None
    
    def construct_quasi_potential(self, 
                                trajectories: np.ndarray, 
                                method: str = 'density') -> Dict:
        """
        Construct quasi-potential U(z) = -ln(P_ss(z)) from trajectory data
        """
        if method == 'density':
            return self._construct_from_density(trajectories)
        elif method == 'transition_matrix':
            return self._construct_from_transitions(trajectories)
        else:
            raise ValueError(f"Unknown method: {method}")
    
    def _construct_from_density(self, trajectories: np.ndarray) -> Dict:
        """Construct potential from steady-state density"""
        # Get final states from all trajectories
        final_states = trajectories[:, -1, :]
        
        # Estimate probability density using kernel density estimation
        from scipy.stats import gaussian_kde
        kde = gaussian_kde(final_states.T)
        
        # Sample points to evaluate potential
        sample_points = final_states  # Use final states as sample points
        densities = kde(sample_points.T)
        
        # Calculate quasi-potential U = -ln(P_ss)
        quasi_potential = -np.log(densities + 1e-10)  # Add small epsilon to avoid log(0)
        
        # Normalize potential
        quasi_potential = quasi_potential - np.min(quasi_potential)
        
        # Find attractors (local minima in potential)
        attractors = self._find_attractors_with_potential(sample_points, quasi_potential)
        
        # Calculate barriers between attractors
        barriers = self._calculate_barriers_between_attractors(
            sample_points, quasi_potential, attractors
        )
        
        return {
            'potential_values': quasi_potential,
            'sample_points': sample_points,
            'attractors': attractors,
            'barriers': barriers,
            'density_estimates': densities,
            'construction_method': 'density_based'
        }
    
    def _find_attractors_with_potential(self, 
                                      points: np.ndarray, 
                                      potential: np.ndarray) -> np.ndarray:
        """Find attractors (stable states) in the potential landscape"""
        # Use clustering to group similar states
        from sklearn.cluster import DBSCAN
        from sklearn.neighbors import NearestNeighbors
        
        # Find nearest neighbors for each point
        nbrs = NearestNeighbors(n_neighbors=min(10, len(points)), algorithm='ball_tree').fit(points)
        distances, indices = nbrs.kneighbors(points)
        
        # For each point, check if it has lower potential than its neighbors
        attractor_candidates = []
        
        for i in range(len(points)):
            neighbor_indices = indices[i][1:]  # Exclude self
            neighbor_potentials = potential[neighbor_indices]
            
            # If this point has lower potential than most neighbors, it's an attractor candidate
            if np.sum(potential[i] < neighbor_potentials) >= len(neighbor_potentials) // 2:
                attractor_candidates.append(i)
        
        if not attractor_candidates:
            # If no clear attractors found, use clustering
            clustering = DBSCAN(eps=np.percentile(distances.flatten(), 25), min_samples=2)
            cluster_labels = clustering.fit_predict(points)
            
            # Find the lowest potential point in each cluster
            attractors = []
            for cluster_id in set(cluster_labels):
                if cluster_id != -1:  # Skip noise points
                    cluster_mask = cluster_labels == cluster_id
                    cluster_potentials = potential[cluster_mask]
                    cluster_indices = np.where(cluster_mask)[0]
                    
                    # Add the index of the lowest potential point in the cluster
                    min_potential_idx = cluster_indices[np.argmin(cluster_potentials)]
                    attractors.append(min_potential_idx)
        else:
            attractors = attractor_candidates
        
        return points[attractors]
    
    def _calculate_barriers_between_attractors(self, 
                                             points: np.ndarray, 
                                             potential: np.ndarray, 
                                             attractors: np.ndarray) -> Dict:
        """Calculate energy barriers between attractor states"""
        n_attractors = len(attractors)
        barriers = {}
        
        if n_attractors < 2:
            return barriers
        
        # For each pair of attractors, calculate the minimal energy barrier
        from scipy.spatial.distance import euclidean
        
        for i in range(n_attractors):
            for j in range(i + 1, n_attractors):
                attractor_i = attractors[i]
                attractor_j = attractors[j]
                
                # Create a path between attractors
                n_steps = 50
                path = []
                for k in range(n_steps + 1):
                    t = k / n_steps
                    point = (1 - t) * attractor_i + t * attractor_j
                    path.append(point)
                
                path = np.array(path)
                
                # Find potential values along the path (interpolated)
                path_potentials = []
                for point in path:
                    # Find nearest point in original data for potential estimate
                    distances = np.linalg.norm(points - point, axis=1)
                    nearest_idx = np.argmin(distances)
                    path_potentials.append(potential[nearest_idx])
                
                path_potentials = np.array(path_potentials)
                
                # Barrier height is the maximum potential along the path minus the minimum
                barrier_height = np.max(path_potentials) - min(potential[i], potential[j])
                
                barriers[f"{i}_{j}"] = {
                    'height': float(barrier_height),
                    'path_maximum': float(np.max(path_potentials)),
                    'path_minimum': float(min(potential[i], potential[j])),
                    'attractor_indices': [int(i), int(j)],
                    'distance': float(euclidean(attractor_i, attractor_j))
                }
        
        return barriers
    
    def visualize_landscape(self, 
                          landscape_ Dict, 
                          save_path: str = None) -> plt.Figure:
        """Visualize the energy landscape"""
        fig, axes = plt.subplots(2, 2, figsize=(15, 12))
        
        # Plot 1: Potential values histogram
        ax1 = axes[0, 0]
        ax1.hist(landscape_data['potential_values'], bins=50, alpha=0.7)
        ax1.set_title('Distribution of Quasi-Potential Values')
        ax1.set_xlabel('Potential')
        ax1.set_ylabel('Frequency')
        
        # Plot 2: Attractor locations (projected to 2D for visualization)
        ax2 = axes[0, 1]
        if len(landscape_data['attractors']) > 0:
            # Use first two dimensions for 2D projection
            attractor_proj = landscape_data['attractors'][:, :2] if landscape_data['attractors'].shape[1] >= 2 else landscape_data['attractors']
            ax2.scatter(attractor_proj[:, 0], attractor_proj[:, 1], c='red', s=100, label='Attractors', zorder=5)
            
            # Also plot some sample points for context
            sample_proj = landscape_data['sample_points'][:, :2] if landscape_data['sample_points'].shape[1] >= 2 else landscape_data['sample_points']
            ax2.scatter(sample_proj[:100, 0], sample_proj[:100, 1], c='blue', alpha=0.3, s=10, label='Sample Points')
            
            ax2.set_title('Attractor Locations (2D Projection)')
            ax2.legend()
        
        # Plot 3: Barrier heights
        ax3 = axes[1, 0]
        if landscape_data['barriers']:
            barrier_heights = [v['height'] for v in landscape_data['barriers'].values()]
            ax3.bar(range(len(barrier_heights)), barrier_heights)
            ax3.set_title('Energy Barriers Between Attractors')
            ax3.set_xlabel('Barrier Pair')
            ax3.set_ylabel('Barrier Height')
        
        # Plot 4: Density vs Potential correlation
        ax4 = axes[1, 1]
        ax4.scatter(landscape_data['density_estimates'], 
                   landscape_data['potential_values'], 
                   alpha=0.5)
        ax4.set_title('Density vs Quasi-Potential')
        ax4.set_xlabel('Density Estimate')
        ax4.set_ylabel('Quasi-Potential')
        ax4.set_yscale('log')
        
        plt.tight_layout()
        
        if save_path:
            plt.savefig(save_path, dpi=300, bbox_inches='tight')
        
        return fig
    
    def apply_superspace_trap(self, 
                            landscape_ Dict, 
                            trap_strength: float = 1.0, 
                            trap_location: np.ndarray = None) -> Dict:
        """
        Apply a superspace trap to homogenize the landscape temporarily
        """
        original_potential = landscape_data['potential_values']
        sample_points = landscape_data['sample_points']
        
        if trap_location is None:
            # Use center of mass of attractors as trap location
            if len(landscape_data['attractors']) > 0:
                trap_location = np.mean(landscape_data['attractors'], axis=0)
            else:
                trap_location = np.mean(sample_points, axis=0)
        
        # Calculate distance from each point to trap location
        distances = np.linalg.norm(sample_points - trap_location, axis=1)
        
        # Create trap potential (harmonic well)
        trap_potential = 0.5 * trap_strength * distances**2
        
        # Modified potential with trap
        modified_potential = original_potential - trap_potential  # Negative sign because trap attracts
        
        # Normalize modified potential
        modified_potential = modified_potential - np.min(modified_potential)
        
        # Update landscape data
        modified_landscape = landscape_data.copy()
        modified_landscape['potential_values'] = modified_potential
        modified_landscape['trap_applied'] = True
        modified_landscape['trap_parameters'] = {
            'strength': trap_strength,
            'location': trap_location.tolist(),
            'type': 'harmonic_well'
        }
        
        return modified_landscape

