    def _combine_predictions(self, pbpk_results: Dict, ml_correction: Dict) -> Dict:
        """
        Combine PBPK and ML predictions
        """
        combined = {}
        for compartment, pbpk_data in pbpk_results.items():
            combined[compartment] = {
                'concentration_timecourse': pbpk_data['concentration_timecourse'],
                'area_under_curve': pbpk_data['area_under_curve'],
                'peak_concentration': pbpk_data['peak_concentration'],
