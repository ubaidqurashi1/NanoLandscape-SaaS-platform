            'has_inf': bool(has_inf),
            'valid': not (has_nan or has_inf)
        }
    
    if 'trajectories' in outputs:
        checks['trajectories_stability'] = check_array_for_issues(
            outputs['trajectories'], 'trajectories'
        )
    
    if 'landscape' in outputs:
        if 'potential_values' in outputs['landscape']:
            checks['landscape_stability'] = check_array_for_issues(
                outputs['landscape']['potential_values'], 'potential_values'
            )
    
    return checks

def _calculate_accuracy_metrics(outputs: Dict, expected: Dict) -> Dict:
    """Calculate accuracy metrics compared to expected values"""
    metrics = {}
    
    # Example: compare predicted vs expected biodistribution
    if 'biodistribution_timecourse' in outputs and 'expected_biodistribution' in expected:
        pred = outputs['biodistribution_timecourse']
        exp = expected['expected_biodistribution']
        
        for organ in exp.keys():
            if organ in pred and 'peak_concentration' in pred[organ]:
                pred_val = pred[organ]['peak_concentration']
                exp_val = exp[organ].get('peak_concentration', 0)
                
                mse = (pred_val - exp_val) ** 2
                r2 = 1 - (mse / (exp_val ** 2 + 1e-8)) if exp_val != 0 else 0
                
                metrics[f'{organ}_accuracy'] = {
                    'predicted': pred_val,
                    'expected': exp_val,
                    'mse': mse,
                    'r2': r2,
                    'error_percent': abs(pred_val - exp_val) / (abs(exp_val) + 1e-8) * 100
                }
    
    return metrics

