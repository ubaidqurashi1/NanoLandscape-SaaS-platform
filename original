"""
Stochastic differential equation solver
"""
import numpy as np
from typing import Callable, Dict, Tuple
from scipy.integrate import solve_ivp
import numba
from numba import jit

class StochasticSolver:
    """
    Advanced SDE solver implementing Euler-Maruyama and higher-order methods
    """
    
    def __init__(self, method: str = 'euler-maruyama'):
        self.method = method
        self.drift_func = None
        self.diffusion_func = None
    
    def set_dynamics_functions(self, 
                             drift_function: Callable, 
                             diffusion_function: Callable):
        """Set the drift and diffusion functions for the SDE"""
        self.drift_func = drift_function
        self.diffusion_func = diffusion_function
    
    def solve_sde(self, 
                 initial_conditions: np.ndarray, 
                 time_span: Tuple[float, float], 
                 dt: float = 0.01,
                 method: str = None) -> np.ndarray:
        """
        Solve the SDE: dx = F(x,t)dt + G(x,t)dW
        """
        if method is None:
            method = self.method
        
        if method == 'euler-maruyama':
            return self._solve_euler_maruyama(initial_conditions, time_span, dt)
        elif method == 'milstein':
            return self._solve_milstein(initial_conditions, time_span, dt)
        else:
            raise ValueError(f"Unknown method: {method}")
    
    def _solve_euler_maruyama(self, 
                            initial_conditions: np.ndarray, 
                            time_span: Tuple[float, float], 
                            dt: float) -> np.ndarray:
        """
        Solve SDE using Euler-Maruyama method
        dx = F(x,t)dt + G(x,t)dW
        """
        t_start, t_end = time_span
        n_timepoints = int((t_end - t_start) / dt) + 1
        time_points = np.linspace(t_start, t_end, n_timepoints)
        
        n_particles = initial_conditions.shape[0]
        n_dimensions = initial_conditions.shape[1]
        
        trajectories = np.zeros((n_particles, n_timepoints, n_dimensions))
        trajectories[:, 0, :] = initial_conditions
        
        for t_idx in range(1, n_timepoints):
            current_time = time_points[t_idx]
            
            for p_idx in range(n_particles):
                x_current = trajectories[p_idx, t_idx-1, :]
                
                # Calculate drift term
                drift = self.drift_func(x_current, current_time)
                
                # Calculate diffusion term
                diffusion_matrix = self.diffusion_func(x_current, current_time)
                
                # Wiener increment
                dW = np.random.normal(0, np.sqrt(dt), n_dimensions)
                
                # Apply diffusion matrix to Wiener increment
                diffusion_term = diffusion_matrix @ dW
                
                # Euler-Maruyama step
                x_next = x_current + drift * dt + diffusion_term
                
                trajectories[p_idx, t_idx, :] = x_next
        
        return trajectories
    
    def _solve_milstein(self, 
                      initial_conditions: np.ndarray, 
                      time_span: Tuple[float, float], 
                      dt: float) -> np.ndarray:
        """
        Solve SDE using Milstein method (more accurate for non-constant diffusion)
        """
        # This is a simplified implementation - full Milstein requires derivatives
        # For now, use Euler-Maruyama as fallback
        return self._solve_euler_maruyama(initial_conditions, time_span, dt)

