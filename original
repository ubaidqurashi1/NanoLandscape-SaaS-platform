"""
Fate Predictor - Biodistribution and fate prediction service
"""
import numpy as np
from typing import Dict, List
import pandas as pd
from scipy.integrate import solve_ivp
from sklearn.ensemble import RandomForestRegressor
from sklearn.multioutput import MultiOutputRegressor

class FatePredictor:
    """
    Predict nanoparticle biodistribution and biological fate using PBPK integration
    """
    
    def __init__(self, engine):
        self.engine = engine
        self.pbpk_model = None
        self.ml_predictor = None
        self.organ_compartments = ['blood', 'liver', 'kidney', 'spleen', 'lung', 'heart', 'muscle', 'fat']
        
    def predict_fate(self, np_parameters: Dict, time_horizon: float = 3600) -> Dict:
        """
        Predict nanoparticle biodistribution over time using PBPK model
        """
        # Extract relevant parameters
        core_params = np_parameters.get('core', {})
        surface_params = np_parameters.get('surface', {})
        corona_params = np_parameters.get('corona', {})
        
        # Calculate key descriptors
        particle_radius = core_params.get('radius', 25.0)
        surface_charge = surface_params.get('zeta_potential', -20.0)
        protein_binding = len(corona_params.get('protein_concentrations', []))
        
        # Run PBPK simulation
        pbpk_results = self._run_pbpbk_simulation(
            particle_radius, surface_charge, protein_binding, time_horizon
        )
        
        # Apply machine learning correction based on historical data
        ml_correction = self._apply_ml_correction(
            particle_radius, surface_charge, protein_binding, pbpk_results
        )
        
        # Combine results
        final_predictions = self._combine_predictions(pbpk_results, ml_correction)
        
        # Calculate fate probabilities
        fate_analysis = self._analyze_fate_probabilities(final_predictions)
        
        result = {
            'biodistribution_timecourse': final_predictions,
            'organ_clearance_rates': self._calculate_clearance_rates(final_predictions),
            'fate_probabilities': fate_analysis,
            'half_life_estimates': self._calculate_half_lives(final_predictions),
            'safety_indicators': self._calculate_safety_indicators(final_predictions),
            'target_organ_specificity': self._calculate_specificity(final_predictions)
        }
        
        return result
    
    def _run_pbpbk_simulation(self, 
                            particle_radius: float, 
                            surface_charge: float, 
                            protein_binding: int, 
                            time_horizon: float) -> Dict:
        """
        Run Physiologically Based Pharmacokinetic simulation
        """
        # Define compartments and parameters
        compartments = {
            'blood': {'volume': 5.0, 'flow': 5.0},      # L, L/hr
            'liver': {'volume': 1.5, 'flow': 1.2},     # L, L/hr
            'kidney': {'volume': 0.3, 'flow': 1.2},    # L, L/hr
            'spleen': {'volume': 0.2, 'flow': 0.1},    # L, L/hr
            'lung': {'volume': 0.5, 'flow': 5.0},      # L, L/hr
            'heart': {'volume': 0.3, 'flow': 0.1},     # L, L/hr
            'muscle': {'volume': 30.0, 'flow': 3.0},   # L, L/hr
            'fat': {'volume': 15.0, 'flow': 0.5}       # L, L/hr
        }
        
        # Calculate organ-specific transfer rates based on particle properties
        transfer_rates = self._calculate_transfer_rates(
            particle_radius, surface_charge, protein_binding, compartments
        )
        
        # Time points for simulation
        t_eval = np.linspace(0, time_horizon/3600, 100)  # Convert seconds to hours
        
        # Initial conditions (all particles start in blood)
        y0 = np.zeros(len(compartments))
        y0[0] = 1.0  # 100% of dose in blood initially
        
        # Solve ODE system
        solution = solve_ivp(
            fun=lambda t, y: self._pbpk_ode_system(t, y, transfer_rates, compartments),
            t_span=[0, time_horizon/3600],
            y0=y0,
            t_eval=t_eval,
            method='RK45'
        )
        
        # Format results
        results = {}
        for i, compartment_name in enumerate(compartments.keys()):
            results[compartment_name] = {
                'concentration_timecourse': solution.y[i].tolist(),
                'area_under_curve': np.trapz(solution.y[i], solution.t),
                'peak_concentration': np.max(solution.y[i]),
                'time_to_peak': solution.t[np.argmax(solution.y[i])] * 3600  # back to seconds
            }
        
        return results
    
    def _calculate_transfer_rates(self, 
                                particle_radius: float, 
                                surface_charge: float, 
                                protein_binding: int, 
                                compartments: Dict) -> Dict:
        """
        Calculate transfer rates between compartments based on particle properties
        """
        base_rates = {
            ('blood', 'liver'): 0.8,
            ('blood', 'kidney'): 0.6,
            ('blood', 'spleen'): 0.3,
            ('blood', 'lung'): 0.9,
            ('liver', 'blood'): 0.7,
            ('kidney', 'blood'): 0.8,
            ('spleen', 'blood'): 0.4,
            ('lung', 'blood'): 0.8,
            ('blood', 'muscle'): 0.1,
            ('blood', 'fat'): 0.05
        }
        
        # Apply particle property corrections
        size_factor = 1.0 / (1.0 + particle_radius/50.0)  # Smaller particles distribute more
        charge_factor = 1.0 / (1.0 + abs(surface_charge)/30.0)  # Neutral particles distribute more
        protein_factor = 1.0 + protein_binding * 0.01  # More protein binding reduces distribution
        
        corrected_rates = {}
        for (source, dest), rate in base_rates.items():
            # Apply corrections
            corrected_rate = rate * size_factor * charge_factor * protein_factor
            
            # Additional corrections for specific organ interactions
            if dest == 'liver' and protein_binding > 50:
                corrected_rate *= 1.5  # Enhanced liver uptake with high protein binding
            elif dest == 'kidney' and particle_radius < 10:
                corrected_rate *= 2.0  # Enhanced kidney filtration for small particles
            elif dest == 'spleen' and surface_charge < -15:
                corrected_rate *= 1.3  # Enhanced MPS uptake for highly negative particles
            
            corrected_rates[(source, dest)] = max(0.01, corrected_rate)  # Minimum rate
        
        return corrected_rates
    
    def _pbpk_ode_system(self, t: float, y: np.ndarray, rates: Dict, compartments: Dict) -> np.ndarray:
        """
        Define the PBPK ODE system
        """
        dydt = np.zeros_like(y)
        compartment_names = list(compartments.keys())
        
        # Blood compartment (index 0)
        blood_conc = y[0]
        for i, comp_name in enumerate(compartment_names):
            if i != 0:  # Not blood
                rate_from_blood = rates.get(('blood', comp_name), 0.0)
                rate_to_blood = rates.get((comp_name, 'blood'), 0.0)
                
                dydt[0] -= rate_from_blood * blood_conc
                dydt[i] = rate_from_blood * blood_conc - rate_to_blood * y[i]
        
        # Handle inter-organ transfers if any
        for (source, dest), rate in rates.items():
            if source != 'blood' and dest != 'blood':
                src_idx = compartment_names.index(source)
                dest_idx = compartment_names.index(dest)
                
                dydt[src_idx] -= rate * y[src_idx]
                dydt[dest_idx] += rate * y[src_idx]
        
        return dydt
    
    def _apply_ml_correction(self, 
                           particle_radius: float, 
                           surface_charge: float, 
                           protein_binding: int, 
                           pbpk_results: Dict) -> Dict:
        """
        Apply machine learning correction based on historical data
