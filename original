"""
Heterogeneity Analyzer - Batch variability and variance amplification analysis
"""
import numpy as np
from typing import Dict, List, Tuple
from scipy.spatial.distance import pdist, squareform
from sklearn.cluster import DBSCAN
from sklearn.metrics import silhouette_score
import matplotlib.pyplot as plt
import seaborn as sns

class HeterogeneityAnalyzer:
    """
    Analyze batch heterogeneity and quantify variance amplification
    """
    
    def __init__(self, engine):
        self.engine = engine
    
    def analyze_batch_heterogeneity(self, simulation_results: Dict) -> Dict:
        """
        Comprehensive heterogeneity analysis of nanoparticle batch
        """
        trajectories = np.array(simulation_results['trajectories'])
        n_particles = trajectories.shape[0]
        n_timepoints = trajectories.shape[1]
        n_dimensions = trajectories.shape[2]
        
        # Calculate various heterogeneity metrics
        metrics = {
            'initial_variance': self._calculate_initial_variance(trajectories),
            'final_variance': self._calculate_final_variance(trajectories),
            'variance_amplification_factor': self._calculate_variance_amplification(trajectories),
            'clustering_analysis': self._perform_clustering_analysis(trajectories),
            'divergence_probability': self._calculate_divergence_probability(trajectories),
            'barrier_crossing_analysis': self._analyze_barrier_crossings(trajectories),
            'fate_distribution': self._analyze_fate_distribution(trajectories)
        }
        
        # Generate heterogeneity report
        report = {
            'analysis_timestamp': np.datetime64('now').astype(str),
            'batch_size': n_particles,
            'total_timepoints': n_timepoints,
            'state_dimensionality': n_dimensions,
            'heterogeneity_metrics': metrics,
            'recommendations': self._generate_recommendations(metrics),
            'visualization_data': self._prepare_visualization_data(trajectories)
        }
        
        return report
    
    def _calculate_initial_variance(self, trajectories: np.ndarray) -> float:
        """Calculate variance among particles at initial time point"""
        initial_states = trajectories[:, 0, :]  # All particles at t=0
        variances = np.var(initial_states, axis=0)
        return np.mean(variances)
    
    def _calculate_final_variance(self, trajectories: np.ndarray) -> float:
        """Calculate variance among particles at final time point"""
        final_states = trajectories[:, -1, :]  # All particles at final time
        variances = np.var(final_states, axis=0)
        return np.mean(variances)
    
    def _calculate_variance_amplification(self, trajectories: np.ndarray) -> float:
        """Calculate how much initial variance was amplified during simulation"""
        initial_var = self._calculate_initial_variance(trajectories)
        final_var = self._calculate_final_variance(trajectories)
        
        if initial_var > 0:
            amplification = final_var / initial_var
        else:
            amplification = 1.0  # No initial variance means no amplification
            
        return amplification
    
    def _perform_clustering_analysis(self, trajectories: np.ndarray) -> Dict:
        """Perform clustering analysis to identify divergent particle populations"""
        final_states = trajectories[:, -1, :]
        
        # Use DBSCAN to find clusters of similar final states
        clustering = DBSCAN(eps=0.5, min_samples=5)
        cluster_labels = clustering.fit_predict(final_states)
        
        n_clusters = len(set(cluster_labels)) - (1 if -1 in cluster_labels else 0)
        n_noise = list(cluster_labels).count(-1)
        
        # Calculate cluster statistics
        cluster_stats = {}
        for cluster_id in set(cluster_labels):
            if cluster_id != -1:  # Skip noise points
                cluster_mask = cluster_labels == cluster_id
                cluster_states = final_states[cluster_mask]
                
                cluster_stats[f'cluster_{cluster_id}'] = {
                    'size': np.sum(cluster_mask),
                    'center': np.mean(cluster_states, axis=0).tolist(),
                    'variance': np.mean(np.var(cluster_states, axis=0)),
                    'fraction_of_total': np.sum(cluster_mask) / len(final_states)
                }
        
        # Calculate silhouette score if we have multiple clusters
        if n_clusters > 1 and len(set(cluster_labels)) > 1:
            if len(set(cluster_labels)) - (1 if -1 in cluster_labels else 0) > 1:
                silhouette_avg = silhouette_score(final_states, cluster_labels)
            else:
                silhouette_avg = 0.0
        else:
            silhouette_avg = 0.0
        
        return {
            'n_clusters': n_clusters,
            'n_noise_points': n_noise,
            'silhouette_score': silhouette_avg,
            'cluster_statistics': cluster_stats,
            'cluster_labels': cluster_labels.tolist()
        }
    
    def _calculate_divergence_probability(self, trajectories: np.ndarray) -> float:
        """Calculate probability that particles diverge significantly from each other"""
        # Calculate pairwise distances between all particle trajectories
        final_states = trajectories[:, -1, :]
        distances = pdist(final_states, metric='euclidean')
        
        # Calculate mean distance between particles
        mean_distance = np.mean(distances)
        
        # Calculate standard deviation of distances
        std_distance = np.std(distances)
        
        # Divergence probability based on how spread out particles are
        # Higher mean distance indicates higher divergence
        divergence_prob = min(1.0, mean_distance / (mean_distance + std_distance + 1e-6))
        
        return divergence_prob
    
    def _analyze_barrier_crossings(self, trajectories: np.ndarray) -> Dict:
        """Analyze potential barrier crossings that lead to different fates"""
        # This is a simplified analysis - in practice, this would involve
        # reconstructing the energy landscape and identifying transition paths
        
        n_particles = trajectories.shape[0]
        n_timepoints = trajectories.shape[1]
        
        # Calculate trajectory complexity as proxy for barrier crossings
        total_path_length = 0
        for i in range(n_particles):
            for t in range(1, n_timepoints):
                displacement = np.linalg.norm(trajectories[i, t, :] - trajectories[i, t-1, :])
                total_path_length += displacement
        
        avg_path_length = total_path_length / n_particles
        
        # Count significant direction changes (possible barrier crossings)
        direction_changes = 0
        for i in range(n_particles):
            for t in range(2, n_timepoints):
                v1 = trajectories[i, t-1, :] - trajectories[i, t-2, :]
                v2 = trajectories[i, t, :] - trajectories[i, t-1, :]
                
                # Calculate angle between consecutive velocity vectors
                cos_angle = np.dot(v1, v2) / (np.linalg.norm(v1) * np.linalg.norm(v2) + 1e-8)
                angle = np.arccos(np.clip(cos_angle, -1, 1))
                
                # If angle > 45 degrees, consider it a direction change
                if angle > np.pi / 4:
                    direction_changes += 1
        
        avg_direction_changes = direction_changes / n_particles
        
        return {
            'average_path_length': avg_path_length,
            'average_direction_changes': avg_direction_changes,
            'estimated_barrier_crossings': avg_direction_changes,
            'complexity_score': avg_path_length * avg_direction_changes
        }
    
    def _analyze_fate_distribution(self, trajectories: np.ndarray) -> Dict:
        """Analyze the distribution of final fates among particles"""
        # This would map final states to biological fates
        # For now, we'll create a mock analysis based on spatial positions
        
        final_positions = trajectories[:, -1, 130:]  # Assuming spatial coordinates are last dims
        
        if final_positions.size > 0:
            # Mock fate assignment based on spatial location
            # In reality, this would use the reconstructed energy landscape
            n_particles = len(final_positions)
            
            # Assign fates based on spatial clustering
            from sklearn.cluster import KMeans
            n_fates = min(5, n_particles // 10)  # Max 5 fates, min 10 particles per fate
            if n_fates >= 2:
                kmeans = KMeans(n_clusters=n_fates, random_state=42)
                fate_labels = kmeans.fit_predict(final_positions)
                
                fate_distribution = {}
                for fate_id in range(n_fates):
                    count = np.sum(fate_labels == fate_id)
                    percentage = (count / n_particles) * 100
                    fate_distribution[f'fate_{fate_id}'] = {
                        'count': int(count),
                        'percentage': round(percentage, 2),
                        'center': kmeans.cluster_centers_[fate_id].tolist() if len(kmeans.cluster_centers_) > fate_id else [0.0, 0.0, 0.0]
                    }
            else:
                # If too few particles, assume single fate
                fate_distribution = {
                    'single_fate': {
                        'count': n_particles,
                        'percentage': 100.0,
                        'center': np.mean(final_positions, axis=0).tolist() if final_positions.ndim > 1 else [0.0, 0.0, 0.0]
                    }
                }
        else:
            fate_distribution = {'undetermined': {'count': 0, 'percentage': 0.0}}
        
        return fate_distribution
    
    def _generate_recommendations(self, metrics: Dict) -> List[str]:
        """Generate recommendations based on heterogeneity analysis"""
        recommendations = []
        
        var_amp = metrics['variance_amplification_factor']
        div_prob = metrics['divergence_probability']
        n_clusters = metrics['clustering_analysis']['n_clusters']
        
        if var_amp > 2.0:
            recommendations.append("High variance amplification detected. Consider adding Superspace Traps to reduce heterogeneity.")
        
        if div_prob > 0.5:
            recommendations.append("High probability of particle divergence. Implement tighter synthesis controls.")
        
        if n_clusters > 3:
            recommendations.append("Multiple distinct particle populations identified. Investigate synthesis consistency.")
        
        if not recommendations:
            recommendations.append("Batch heterogeneity appears acceptable. Continue current synthesis protocol.")
        
        return recommendations
    
    def _prepare_visualization_data(self, trajectories: np.ndarray) -> Dict:
        """Prepare data for visualization"""
        # Sample trajectories for plotting (to avoid memory issues with large datasets)
        n_sample = min(100, trajectories.shape[0])
        sample_indices = np.random.choice(trajectories.shape[0], n_sample, replace=False)
        sampled_trajectories = trajectories[sample_indices]
        
        # Calculate summary statistics
        mean_trajectory = np.mean(sampled_trajectories, axis=0)
        std_trajectory = np.std(sampled_trajectories, axis=0)
        
        return {
            'sampled_trajectories': sampled_trajectories.tolist(),
            'mean_trajectory': mean_trajectory.tolist(),
            'std_trajectory': std_trajectory.tolist(),
