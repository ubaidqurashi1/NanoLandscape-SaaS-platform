    """
    
    def __init__(self, db_path: str = "nanolandscape.db"):
        self.db_path = db_path
        self._initialize_database()
    
    def _initialize_database(self):
        """Initialize the SQLite database with required tables"""
        conn = sqlite3.connect(self.db_path)
        cursor = conn.cursor()
        
        # Create simulations table
        cursor.execute('''
            CREATE TABLE IF NOT EXISTS simulations (
                id TEXT PRIMARY KEY,
                timestamp DATETIME DEFAULT CURRENT_TIMESTAMP,
                parameters_json TEXT,
                results_json TEXT,
                summary_json TEXT,
                hash TEXT UNIQUE,
                status TEXT DEFAULT 'completed'
            )
        ''')
        
        # Create designs table
        cursor.execute('''
            CREATE TABLE IF NOT EXISTS designs (
                id TEXT PRIMARY KEY,
                timestamp DATETIME DEFAULT CURRENT_TIMESTAMP,
                design_request_json TEXT,
                design_results_json TEXT,
                optimization_history_json TEXT,
                status TEXT DEFAULT 'completed'
            )
        ''')
        
        # Create analyses table
        cursor.execute('''
            CREATE TABLE IF NOT EXISTS analyses (
                id TEXT PRIMARY KEY,
                timestamp DATETIME DEFAULT CURRENT_TIMESTAMP,
                analysis_type TEXT,
                input_data_json TEXT,
                results_json TEXT,
                status TEXT DEFAULT 'completed'
            )
        ''')
        
        # Create metadata table
        cursor.execute('''
            CREATE TABLE IF NOT EXISTS metadata (
                key TEXT PRIMARY KEY,
                value TEXT,
                updated_at DATETIME DEFAULT CURRENT_TIMESTAMP
            )
        ''')
        
        conn.commit()
        conn.close()
    
    async def store_simulation(self, simulation_ Dict):
        """Store simulation results in database"""
        conn = sqlite3.connect(self.db_path)
        cursor = conn.cursor()
        
        # Create hash of parameters for uniqueness
        params_hash = hashlib.md5(
            json.dumps(simulation_data.get('simulation_id', ''), sort_keys=True).encode()
        ).hexdigest()
        
        cursor.execute('''
            INSERT OR REPLACE INTO simulations 
            (id, parameters_json, results_json, summary_json, hash, status)
            VALUES (?, ?, ?, ?, ?, ?)
        ''', (
            simulation_data.get('simulation_id'),
            json.dumps(simulation_data.get('trajectories', [])),
            json.dumps(simulation_data.get('landscape', {})),
            json.dumps(simulation_data.get('summary_statistics', {})),
            params_hash,
            'completed'
        ))
        
        conn.commit()
        conn.close()
    
    async def get_simulation(self, simulation_id: str) -> Optional[Dict]:
        """Retrieve simulation results by ID"""
        conn = sqlite3.connect(self.db_path)
        cursor = conn.cursor()
        
        cursor.execute('SELECT * FROM simulations WHERE id = ?', (simulation_id,))
        row = cursor.fetchone()
        
        if row:
            result = {
                'id': row[0],
                'timestamp': row[1],
                'trajectories': json.loads(row[2]),
                'landscape': json.loads(row[3]),
                'summary_statistics': json.loads(row[4]),
                'status': row[6]
            }
        else:
            result = None
        
        conn.close()
        return result
    
    async def store_design(self, design_ Dict):
