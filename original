        conn = sqlite3.connect(self.db_path)
        cursor = conn.cursor()
        
        cursor.execute('''
            INSERT INTO designs 
            (id, design_request_json, design_results_json, optimization_history_json, status)
            VALUES (?, ?, ?, ?, ?)
        ''', (
            design_data.get('best_parameters', {}).get('id', str(hash(design_data.get('target_organ', '')))),
            json.dumps(design_data.get('design_request', {})),
            json.dumps(design_data.get('optimal_design', {})),
            json.dumps(design_data.get('optimization_trials', [])),
            'completed'
        ))
        
        conn.commit()
        conn.close()
    
    async def get_analyses_by_type(self, analysis_type: str, limit: int = 100) -> List[Dict]:
        """Get analyses of a specific type"""
        conn = sqlite3.connect(self.db_path)
        cursor = conn.cursor()
        
        cursor.execute('''
            SELECT id, timestamp, results_json FROM analyses 
            WHERE analysis_type = ? ORDER BY timestamp DESC LIMIT ?
        ''', (analysis_type, limit))
        
        rows = cursor.fetchall()
        results = []
        
        for row in rows:
            results.append({
                'id': row[0],
                'timestamp': row[1],
                'results': json.loads(row[2])
            })
        
        conn.close()
        return results
    
    async def update_metadata(self, key: str, value: str):
        """Update metadata entry"""
        conn = sqlite3.connect(self.db_path)
        cursor = conn.cursor()
        
        cursor.execute('''
            INSERT OR REPLACE INTO metadata (key, value) VALUES (?, ?)
        ''', (key, value))
        
        conn.commit()
        conn.close()
    
    async def get_metadata(self, key: str) -> Optional[str]:
        """Get metadata entry"""
        conn = sqlite3.connect(self.db_path)
        cursor = conn.cursor()
        
        cursor.execute('SELECT value FROM metadata WHERE key = ?', (key,))
        row = cursor.fetchone()
        
        conn.close()
        return row[0] if row else None

