            }
        
        return combined
    
    def _analyze_fate_probabilities(self, predictions: Dict) -> Dict:
        """
        Analyze probabilities of different biological fates
        """
        # Calculate AUC ratios to determine fate probabilities
        total_auc = sum(data['area_under_curve'] for data in predictions.values())
        
        fate_probs = {}
        for compartment, data in predictions.items():
            auc_fraction = data['area_under_curve'] / (total_auc + 1e-10)
            fate_probs[compartment] = {
                'probability': auc_fraction,
                'primary_fate': auc_fraction > 0.3,
                'secondary_fate': 0.1 < auc_fraction <= 0.3
            }
        
        # Identify clearance pathways
        clearance_organs = ['kidney', 'liver', 'spleen']
        clearance_prob = sum(fate_probs[organ]['probability'] for organ in clearance_organs 
                           if organ in fate_probs)
        
        fate_probs['clearance_probability'] = clearance_prob
        fate_probs['bioavailability'] = 1.0 - clearance_prob
        
        return fate_probs
    
    def _calculate_clearance_rates(self, predictions: Dict) -> Dict:
        """
        Calculate organ-specific clearance rates
        """
        clearances = {}
        
        for compartment, data in predictions.items():
            # Clearance = AUC / initial concentration (assuming 100% bioavailable)
            clearance = data['area_under_curve'] / (data['peak_concentration'] + 1e-10)
            clearances[compartment] = {
                'clearance_rate_L_per_hour': clearance,
                'elimination_half_life_hours': np.log(2) / clearance if clearance > 0 else float('inf')
            }
        
        return clearances
    
    def _calculate_half_lives(self, predictions: Dict) -> Dict:
        """
        Calculate half-lives in different organs
        """
        half_lives = {}
        
        for compartment, data in predictions.items():
            # Estimate elimination rate constant from AUC and peak
            if data['peak_concentration'] > 0 and data['area_under_curve'] > 0:
                ke = data['peak_concentration'] / data['area_under_curve']
                t_half = np.log(2) / ke if ke > 0 else float('inf')
            else:
                t_half = float('inf')
            
            half_lives[compartment] = t_half
        
        return half_lives
    
    def _calculate_safety_indicators(self, predictions: Dict) -> Dict:
        """
        Calculate safety-related indicators
        """
        safety_indicators = {
            'liver_exposure': predictions.get('liver', {}).get('area_under_curve', 0),
            'kidney_exposure': predictions.get('kidney', {}).get('area_under_curve', 0),
            'max_organ_concentration': max(
                [data.get('peak_concentration', 0) for data in predictions.values()]
            ),
            'exposure_ratio_liver_kidney': (
                predictions.get('liver', {}).get('area_under_curve', 0) /
                (predictions.get('kidney', {}).get('area_under_curve', 0) + 1e-10)
            )
        }
        
        # Risk assessment
        risk_level = 'LOW'
        if safety_indicators['liver_exposure'] > 2.0 or safety_indicators['kidney_exposure'] > 1.5:
            risk_level = 'MODERATE'
        if safety_indicators['liver_exposure'] > 5.0 or safety_indicators['kidney_exposure'] > 3.0:
            risk_level = 'HIGH'
        
        safety_indicators['overall_risk_level'] = risk_level
        
        return safety_indicators
    
    def _calculate_specificity(self, predictions: Dict) -> Dict:
        """
        Calculate target organ specificity
        """
        # Assume blood is the target for systemic delivery
        target_compartment = 'blood'
        target_auc = predictions.get(target_compartment, {}).get('area_under_curve', 0)
        
        # Calculate specificity as ratio of target to total exposure
        total_auc = sum(data.get('area_under_curve', 0) for data in predictions.values())
        specificity = target_auc / (total_auc + 1e-10)
        
        # Calculate selectivity index (ratio of target to off-target)
        off_target_auc = total_auc - target_auc
        selectivity = target_auc / (off_target_auc + 1e-10) if off_target_auc > 0 else float('inf')
        
        return {
            'specificity_index': specificity,
            'selectivity_index': selectivity,
            'target_enrichment_ratio': target_auc / (predictions.get('liver', {}).get('area_under_curve', 0) + 1e-10)
        }

