@cli.command()
@click.argument('input_file', type=click.Path(exists=True))
@click.option('--output', '-o', type=click.Path(), help='Output file for results')
@click.option('--ensemble-size', '-n', default=100, help='Number of particles in ensemble')
def simulate(input_file, output, ensemble_size):
    """Run a nanoparticle simulation from input file"""
    with open(input_file, 'r') as f:
        input_data = json.load(f)
    
    engine = SuperspaceEngine()
    
    # Parse input parameters
    np_params = input_data['np_parameters']
    time_horizon = input_data.get('time_horizon', 3600)
    noise_level = input_data.get('noise_level', 0.01)
    lambda_params = input_data.get('lambda_params', {})
    
    # Run simulation
    state_vector = engine.construct_state_vector(
        np_params['core'], np_params['surface'], 
        np_params['corona'], np_params['context'], np_params['spatial']
    )
    
    initial_conditions = engine.generate_initial_conditions(
        state_vector, ensemble_size, noise_level
    )
    
    time_points = np.linspace(0, time_horizon, 
                            int(time_horizon / engine.config['dt']) + 1)
    
    trajectories = engine.solve_stochastic_differential_equation(
        initial_conditions, time_points, lambda_params
    )
    
    landscape_data = engine.reconstruct_energy_landscape(trajectories)
    
    results = {
        'trajectories': trajectories.tolist(),
        'time_points': time_points.tolist(),
        'landscape': landscape_data,
        'summary_statistics': {
            'mean_final_positions': np.mean(trajectories[:, -1, :], axis=0).tolist(),
            'std_final_positions': np.std(trajectories[:, -1, :], axis=0).tolist(),
            'ensemble_size': ensemble_size,
            'time_horizon': time_horizon
        }
    }
    
    if output:
        with open(output, 'w') as f:
            json.dump(results, f, indent=2)
        click.echo(f"Results saved to {output}")
    else:
        click.echo(json.dumps(results, indent=2))

if __name__ == '__main__':
    cli()

